{
  "name": "pipeflow-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"const{execSync}=require('child_process');try{const r=execSync('netstat -ano',{encoding:'utf8'});const m=r.match(/:3000\\s+.*LISTENING\\s+(\\d+)/);if(m)execSync('taskkill /F /PID '+m[1])}catch{}\"",
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@dnd-kit/core": "^6",
    "@dnd-kit/sortable": "^8",
    "@dnd-kit/utilities": "^3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0",
    "@supabase/supabase-js": "^2",
    "class-variance-authority": "^0",
    "clsx": "^2",
    "date-fns": "^3",
    "lucide-react": "^0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2",
    "stripe": "^14",
    "tailwind-merge": "^2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
