# ============================================================
# PipeFlow CRM — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha com seus valores.
# NUNCA commite o .env.local no Git.
# ============================================================

# ---------- SUPABASE ----------
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
# Nota: SUPABASE_SERVICE_ROLE_KEY não é mais necessário no app Next.js.
# O webhook do Stripe agora roda como Supabase Edge Function.

# ---------- STRIPE ----------
STRIPE_SECRET_KEY=sk_test_...sua_secret_key_aqui
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...sua_publishable_key_aqui
STRIPE_PRICE_ID=price_...id_do_preco_pro_aqui
# Nota: STRIPE_WEBHOOK_SECRET agora é configurado como secret na Edge Function.
# Use: npx supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...

# ---------- RESEND ----------
RESEND_API_KEY=re_...sua_api_key_aqui

# ---------- APP ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
